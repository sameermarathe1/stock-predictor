# Optional OpenAI setup for true LLM-backed analyst debate.
# If these are not set, the app falls back to its built-in rules-based debate mode.
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_COUNSEL_MODELS=gpt-5,gpt-5-mini,gpt-4.1-mini
OPENAI_COUNSEL_MAX_MEMBERS=5
OPENAI_COUNSEL_TIMEOUT_SECONDS=90
OPENAI_BASE_URL=https://api.openai.com/v1

# Local web server settings.
HOST=127.0.0.1
PORT=8000
REQUEST_TIMEOUT_SECONDS=18
SUGGESTIONS_CACHE_SECONDS=900
